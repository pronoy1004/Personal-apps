# ---- Auth (single-password gate for the whole hub) ----
# The password you type on /login. Change this.
APP_PASSWORD=changeme
# JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ---- Fitness (Pro-Fit engine, Prisma over MongoDB) ----
# Same cluster as MONGODB_URI below, own database/collections. Include a db
# name in the path, e.g. mongodb+srv://user:pass@cluster/profit
DATABASE_URL=

# ---- Other apps (optional; localStorage fallback if unset) ----
MONGODB_URI=
NEXT_PUBLIC_APP_URL=
CALORIE_NINJAS_API_KEY=
TMDB_API_KEY=
# OpenAI key for fitness AI insights (optional)
OPENAI_API_KEY=
